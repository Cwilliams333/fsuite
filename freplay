# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

main() {
  local cmd="${1:---help}"
  case "$cmd" in
    --help|-h|help)
      usage
      ;;
    --version|version)
      echo "freplay ${VERSION}"
      ;;
    --self-check|self-check)
      cmd_self_check
      ;;
    record)
      shift
      cmd_record "$@"
      ;;
    show)
      shift
      cmd_show "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    export)
      shift
      cmd_export "$@"
      ;;
    verify)
      shift
      cmd_verify "$@"
      ;;
    promote)
      shift
      cmd_promote "$@"
      ;;
    archive)
      shift
      cmd_archive "$@"
      ;;
    *)
      die 2 "unknown subcommand: $cmd"
      ;;
  esac
}

main "$@"
